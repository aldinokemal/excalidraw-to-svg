{
  "name": "@aldinokemal2104/excalidraw-to-svg",
  "version": "1.1.0",
  "description": "Node Library to transform excalidraw diagrams into svgs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aldinokemal/excalidraw-to-svg.git"
  },
  "homepage": "https://github.com/aldinokemal/excalidraw-to-svg#readme",
  "bugs": {
    "url": "https://github.com/aldinokemal/excalidraw-to-svg/issues"
  },
  "main": "src/excalidraw-to-svg.js",
  "types": "src/excalidraw-to-svg.d.ts",
  "bin": {
    "excalidraw-to-svg": "src/cli.js"
  },
  "scripts": {
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest src/*.test.js",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest src/*.test.js --watch",
    "test:integration": "node test/globals-clean.js && node test/sample.js && node test/import.js && node test/warm-worker-impact.js",
    "prepublishOnly": "npm test",
    "npm:publish": "NPM_TOKEN=${NPM_TOKEN:?'NPM_TOKEN is required'} && echo \"//registry.npmjs.org/:_authToken=${NPM_TOKEN}\" > .npmrc && npm publish --access public && rm -f .npmrc"
  },
  "keywords": [
    "excalidraw",
    "svg",
    "utils"
  ],
  "author": {
    "name": "GroupMap Dev",
    "email": "aldino@groupmap.com",
    "url": "https://teamretro.com"
  },
  "license": "MIT",
  "dependencies": {
    "@excalidraw/utils": "0.1.3-test32",
    "jsdom": "^24.0.0",
    "subset-font": "^2.4.0"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "prettier": "^2.8.7"
  }
}
